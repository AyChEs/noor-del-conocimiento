rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'luzdelsaber.juego@gmail.com';
    }

    // ──────────────────────────────────────────────────────────
    // Perfiles de usuario
    // Solo el propio usuario puede leer y escribir su perfil. Los admins pueden todo.
    // ──────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());

      // Historial de preguntas (SRS) — mismo propietario
      match /questionHistory/{questionId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }

    // ──────────────────────────────────────────────────────────
    // Tabla de clasificación (Musafir)
    // - Cualquiera puede leer (incluso sin sesión)
    // - Solo el propio usuario puede escribir su propia entrada
    // - totalScore solo puede subir (anti-trampa)
    // - bestScore es el mejor individual (0-100)
    // ──────────────────────────────────────────────────────────
    match /leaderboard/{uid} {
      allow read: if true;
      allow delete: if isAdmin();

      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.totalScore is int
                    && request.resource.data.totalScore >= 0
                    && request.resource.data.bestScore is int
                    && request.resource.data.bestScore >= 0
                    && request.resource.data.bestScore <= 100;

      allow update: if request.auth != null
                    && (
                      (request.auth.uid == uid
                       && request.resource.data.totalScore >= resource.data.totalScore
                       && request.resource.data.bestScore >= resource.data.bestScore)
                      || isAdmin()
                    );
    }
  }
}
